# ─── Secrets (critical — never commit) ───────────────────────────────
.env
.env.local
.env.*
!.env.example
*.secret
stellar-keys/

# ─── Trusted-setup toxic waste (critical — never commit) ──────────────
# Intermediate Powers-of-Tau / phase-2 contributions carry private
# randomness. Leaking them compromises soundness of EVERY proof.
# When unsure whether a setup artifact is safe, IGNORE it and ask.
circuits/build/*.ptau
# Policy: only the final, public ptau is ever safe to commit. For now even
# final.ptau stays ignored — it is 6.8M (>1MB rule) and fully regenerable via
# `pnpm --filter @zeekpay/circuits bench`. Re-enable the negation below only if
# a demo genuinely needs a committed, intentionally-published final.ptau.
# !circuits/build/final.ptau
circuits/build/contributions/
circuits/build/*_contribution_*

# ─── Build artifacts ──────────────────────────────────────────────────
# Rust / Soroban
contracts/target/
**/*.rs.bk

# Circom intermediates (keep verification_key.json / proof.json / public.json if needed for demo)
circuits/build/*.r1cs
circuits/build/*.sym
circuits/build/*_js/
# Regenerable proving artifacts (large / setup material — reproduce via bench script)
circuits/build/*.zkey
circuits/build/*.wtns

# Soroban test snapshots (regenerated by `cargo test`)
**/test_snapshots/

# Node
node_modules/
pnpm-lock.yaml.bak
.pnpm-store/

# Next.js
.next/
out/

# TypeScript
dist/
*.tsbuildinfo

# ─── Runtime data (regenerable / PII risk) ────────────────────────────
backend/data/registry.json
backend/data/_test_registry.json

# ─── Tooling noise ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
pnpm-debug.log*
.vscode/*
# commit shared editor settings only:
!.vscode/settings.json
.idea/
