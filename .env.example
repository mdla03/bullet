# Bullet environment template.
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# This file carries NO real values — placeholders only.

# ─── Stellar / Soroban ───────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ZEEKPAY_CONTRACT_ID=
USDC_SAC_ID=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Deployer (NEVER commit a real value) ────────────────────────────
DEPLOYER_SECRET_KEY=

# ─── Admin / relayer (NEVER commit a real value) ─────────────────────
# Must be the address set as admin during contract initialize().
# Backend (deposit indexer) uses this to call post_root after confirming
# on-chain deposit events.
ZEEKPAY_ADMIN_KEY=

# ─── Invite custody (NEVER commit real values) ───────────────────────
# Master funder that seeds per-invite custody accounts.
BULLET_CUSTODY_MASTER_SECRET=
# 32-byte hex (64 chars) key used to encrypt custody Stellar secrets at rest
# in pending_invites. REQUIRED for the invite flow; without it the backend
# refuses to store custody secrets (fail closed). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BULLET_CUSTODY_ENC_KEY=

# ─── Supabase (backend) ──────────────────────────────────────────────
# SUPABASE_URL and SUPABASE_ANON_KEY are safe to expose.
# SUPABASE_SERVICE_ROLE_KEY is a SECRET; backend-only. Grab it from
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Backend resolver ────────────────────────────────────────────────
RESOLVER_PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Frontend (NEXT_PUBLIC_* are exposed to the browser) ─────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_CONTRACT_ID=
NEXT_PUBLIC_RESOLVER_URL=http://localhost:3001
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
