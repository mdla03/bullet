# ZeekPay environment template.
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# This file carries NO real values — placeholders only.

# ─── Stellar / Soroban ───────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ZEEKPAY_CONTRACT_ID=
USDC_SAC_ID=
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Deployer (NEVER commit a real value) ────────────────────────────
DEPLOYER_SECRET_KEY=

# ─── Admin / relayer (NEVER commit a real value) ─────────────────────
# Must be the address set as admin during contract initialize().
# Backend uses this to call post_root after proof generation.
ZEEKPAY_ADMIN_KEY=

# ─── Backend resolver ────────────────────────────────────────────────
RESOLVER_PORT=3001
DATABASE_URL=

# ─── X OAuth (x-oauth-identity feature) ──────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_CALLBACK_URL=

# ─── SendGrid (P1) ───────────────────────────────────────────────────
SENDGRID_API_KEY=

# ─── Frontend (NEXT_PUBLIC_* are exposed to the browser) ─────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_CONTRACT_ID=
NEXT_PUBLIC_RESOLVER_URL=http://localhost:3001
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
