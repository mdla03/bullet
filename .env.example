# ZeekPay environment template.
# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).
# This file carries NO real values — placeholders only.

# ─── Stellar / Soroban ───────────────────────────────────────────────
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=
ZEEKPAY_CONTRACT_ID=
USDC_SAC_ID=

# ─── Deployer (NEVER commit a real value) ────────────────────────────
DEPLOYER_SECRET_KEY=

# ─── Backend resolver ────────────────────────────────────────────────
RESOLVER_PORT=
DATABASE_URL=

# ─── X OAuth (x-oauth-identity feature) ──────────────────────────────
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_CALLBACK_URL=

# ─── SendGrid (P1) ───────────────────────────────────────────────────
SENDGRID_API_KEY=

# ─── Frontend (NEXT_PUBLIC_* are exposed to the browser) ─────────────
NEXT_PUBLIC_SOROBAN_RPC_URL=
NEXT_PUBLIC_CONTRACT_ID=
NEXT_PUBLIC_RESOLVER_URL=
